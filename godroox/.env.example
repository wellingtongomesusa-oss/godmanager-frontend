# Database
DATABASE_URL="postgresql://user:password@localhost:5432/godroox?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# Application Port (default: 8081)
APP_PORT=8081

# NextAuth
NEXTAUTH_URL="http://localhost:8081"
NEXTAUTH_SECRET="your-secret-key-here-change-in-production"

# BigQuery (Analytics)
GOOGLE_CLOUD_PROJECT_ID="your-project-id"
GOOGLE_APPLICATION_CREDENTIALS="path/to/credentials.json"
BIGQUERY_DATASET="godroox_analytics"

# External APIs
INSURANCE_API_KEY=""
INSURANCE_API_URL=""
FLORIDA_LLC_API_KEY=""
FLORIDA_LLC_API_URL=""
PAYMENT_PROVIDER_API_KEY=""
PAYMENT_PROVIDER_API_URL=""

# Sentry (Error Tracking)
SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""

# CORS (inclua http://localhost:3001 se o dashboard rodar nessa origem)
ALLOWED_ORIGINS="http://localhost:8081,http://localhost:3001"

# Dashboard – chave para o dashboard (localhost:3001) acessar a API de cadastros
# Deve ser igual a DASHBOARD_API_SECRET no .env do dashboard-godroox
DASHBOARD_API_SECRET="sua-senha-secreta-dashboard"

# API Rate Limiting
RATE_LIMIT_REDIS_URL="redis://localhost:6379"

# Partner API
PARTNER_API_RATE_LIMIT=100
PARTNER_API_RATE_WINDOW=3600

# Formulário de contato (página /contact)
# E-mail: enviado para contact@godroox.com. Alerta SMS para +1 321 519 4710 (se Twilio configurado).
RESEND_API_KEY=
RESEND_FROM=Godroox Contact <onboarding@resend.dev>
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
