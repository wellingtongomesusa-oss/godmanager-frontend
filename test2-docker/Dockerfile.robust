# Dockerfile alternativo mais robusto
# Use este se o Dockerfile principal falhar
FROM python:3.11-slim

# Metadados
LABEL maintainer="Algo Trading System"
LABEL description="Sistema de Trading Algorítmico - Versão Robusta"

# Variáveis de ambiente
ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1

# Diretório de trabalho
WORKDIR /app

# Instalar dependências do sistema
RUN apt-get update && apt-get install -y \
    gcc \
    g++ \
    postgresql-client \
    curl \
    make \
    cmake \
    libpq-dev \
    && rm -rf /var/lib/apt/lists/*

# Copiar requirements e instalar dependências Python
COPY requirements.txt .

# Atualizar pip
RUN pip install --upgrade pip setuptools wheel

# Instalar apenas dependências essenciais (MVP)
RUN pip install \
    numpy \
    pandas \
    scipy \
    psycopg2-binary \
    sqlalchemy \
    redis \
    fastapi \
    uvicorn[standard] \
    python-dotenv \
    pydantic \
    pydantic-settings \
    loguru \
    prometheus-client

# Tentar instalar dependências opcionais (não falhar se não funcionar)
RUN pip install polygon-api-client || echo "polygon-api-client falhou (opcional)"
RUN pip install alpaca-trade-api || echo "alpaca-trade-api falhou (opcional)"
RUN pip install backtrader || echo "backtrader falhou (opcional)"
RUN pip install pandas-ta || echo "pandas-ta falhou (opcional)"
RUN pip install py_vollib || echo "py_vollib falhou (opcional)"

# Copiar código fonte
COPY . .

# Criar diretórios necessários
RUN mkdir -p /app/data /app/logs /app/config

# Expor porta
EXPOSE 8000

# Comando padrão
CMD ["python", "-m", "src.main"]
