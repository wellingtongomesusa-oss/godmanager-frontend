# Database
DB_USER=algo_trader
DB_PASSWORD=secure_password_change
DB_NAME=trading_db
DB_HOST=timescaledb
DB_PORT=5432

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Trading Mode
MODE=paper  # paper, live

# Data Providers
DATA_PROVIDER=polygon  # polygon, iex, tradier, ib, alpaca

# Polygon API
POLYGON_API_KEY=your_polygon_api_key

# Interactive Brokers
IB_HOST=127.0.0.1
IB_PORT=7497  # 7497 paper, 7496 live

# Alpaca
ALPACA_API_KEY=your_alpaca_key
ALPACA_SECRET_KEY=your_alpaca_secret
ALPACA_BASE_URL=https://paper-api.alpaca.markets  # paper
# ALPACA_BASE_URL=https://api.alpaca.markets  # live

# Tradier
TRADIER_API_KEY=your_tradier_key
TRADIER_ACCOUNT_ID=your_account_id

# Risk Limits
MAX_DAILY_LOSS=0.02  # 2%
MAX_WEEKLY_LOSS=0.05  # 5%
MAX_POSITION_SIZE=10000  # USD
MAX_ORDERS_PER_MINUTE=10

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/trading.log

# Monitoring
GRAFANA_PASSWORD=admin
ENABLE_MONITORING=false
