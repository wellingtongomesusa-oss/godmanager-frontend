# Dashboard Godroox (porta 3001) – link no menu
NEXT_PUBLIC_GODROOX_DASHBOARD_URL=http://localhost:3001

# GodCRM (este dashboard, porta 3000)
GODCRM_DASHBOARD_URL=http://localhost:3000

# Plano padrão ao carregar (1, 2 ou 3)
NEXT_PUBLIC_DEFAULT_PLAN=2

# E-mail – provedor e chaves (nunca expor chaves no frontend)
# EMAIL_PROVIDER=gmail|outlook|sendgrid|mailgun|ses
# SENDGRID_API_KEY=
# MAILGUN_API_KEY=
# GMAIL_CLIENT_ID=
# GMAIL_CLIENT_SECRET=
# GMAIL_REDIRECT_URI=

# Stripe (checkout Pro trial 7 dias + webhook)
# STRIPE_SECRET_KEY=sk_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_...
# ID do preço da assinatura Pro (Stripe Dashboard → Products → Preço recorrente)
# STRIPE_PRICE_ID_PRO=price_...

# Claude / Anthropic API
# ANTHROPIC_API_KEY=

# E-mail profissional @godcrm.com (Plano 3)
NEXT_PUBLIC_EMAIL_DOMAIN=godcrm.com
# EMAIL_PROVISIONING_PROVIDER=
# EMAIL_PROVISIONING_API_KEY=
