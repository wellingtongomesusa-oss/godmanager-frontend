# Copie para `.env` na raiz do GodManager e preencha.
# Flask — OAuth em localhost (http): use development OU SESSION_COOKIE_SECURE=false
# FLASK_ENV=development
# SESSION_COOKIE_SECURE=false
#
# QuickBooks (Intuit Developer) — OAuth2
# 1) No portal Intuit (Keys & Credentials), copie Client ID e Client Secret (nunca commite o secret).
# 2) Em "Redirect URIs", adicione EXACTAMENTE o callback (exemplo Railway):
#    https://SEU-SERVICO.up.railway.app/crm/integrations/quickbooks/callback
# 3) Opção A — URL completa:
# QB_REDIRECT_URI=https://SEU-SERVICO.up.railway.app/crm/integrations/quickbooks/callback
# 4) Opção B — só a origem pública (o path /crm/integrations/quickbooks/callback é acrescentado no código):
# QB_PUBLIC_BASE_URL=https://SEU-SERVICO.up.railway.app
# 5) Sandbox: QB_ENVIRONMENT=sandbox e empresa de teste no QuickBooks Sandbox.
# 6) Produção: QB_ENVIRONMENT=production e QB_BASE_URL=https://quickbooks.api.intuit.com
QB_CLIENT_ID=
QB_CLIENT_SECRET=
QB_REDIRECT_URI=http://localhost:3101/crm/integrations/quickbooks/callback
QB_PUBLIC_BASE_URL=
QB_ENVIRONMENT=sandbox
QB_BASE_URL=https://sandbox-quickbooks.api.intuit.com
