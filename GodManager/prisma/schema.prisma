model BillingDocument {
  id               String            @id @default(cuid())
  clientId         String?
  docType          String
  number           String
  status           String            @default("DRAFT")
  contactName      String
  contactEmail     String?
  contactPhone     String?
  receiverName     String?
  receiverAddress  String?
  receiverEmail    String?
  receiverPhone    String?
  billingContactId String?
  vendorId         String?
  propertyId       String?
