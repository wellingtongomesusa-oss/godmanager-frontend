// Prisma schema - GodManager
// Replica lib/types.ts: User + Client + AuditEntry
// Multi-tenant: User.clientId opcional (null = system admin)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  manager
  accountant
  leasing
  maintenance
  viewer
}

enum UserStatus {
  active
  suspended
  pending
}

enum ClientPlan {
  starter
  professional
  enterprise
}

model Client {
  id          String     @id @default(cuid())
  companyName String
  contactName String
  email       String     @unique
  phone       String?
  address     String?
  plan        ClientPlan @default(starter)
  accessLevel UserRole   @default(manager)
  active      Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  users       User[]

  @@map("clients")
}

model User {
  id           String       @id @default(cuid())
  firstName    String
  lastName     String
  email        String       @unique
  phone        String?
  role         UserRole     @default(viewer)
  status       UserStatus   @default(pending)
  permissions  String[]     @default([])
  passwordHash String
  createdAt    DateTime     @default(now())
  lastActive   DateTime     @default(now())
  clientId     String?
  client       Client?      @relation(fields: [clientId], references: [id], onDelete: SetNull)
  auditEntries AuditEntry[] @relation("ActorAudit")
  targetAudits AuditEntry[] @relation("TargetAudit")

  @@index([clientId])
  @@index([email])
  @@map("users")
}

model AuditEntry {
  id           String   @id @default(cuid())
  actorId      String
  actor        User     @relation("ActorAudit", fields: [actorId], references: [id], onDelete: Cascade)
  action       String
  targetUserId String?
  targetUser   User?    @relation("TargetAudit", fields: [targetUserId], references: [id], onDelete: SetNull)
  details      String
  ip           String?
  timestamp    DateTime @default(now())

  @@index([actorId])
  @@index([targetUserId])
  @@index([timestamp])
  @@map("audit_entries")
}

model Property {
  id         String   @id @default(cuid())
  code       String   @unique
  address    String
  city       String?
  state      String?
  zip        String?
  unitType   String?
  bedrooms   Int?
  bathrooms  Float?
  rent       Decimal  @default(0) @db.Decimal(10, 2)
  deposit    Decimal  @default(0) @db.Decimal(10, 2)
  guaranteeLimit Decimal? @db.Decimal(10, 2)
  moveInDate     DateTime?
  ownerName  String?
  ownerEmail String?
  ownerPhone String?
  mgmtFeePct Decimal  @default(0) @db.Decimal(5, 2)
  status     String   @default("active")
  notes      String?  @db.Text
  metadata   Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  createdBy  String?
  tenants    Tenant[]
  pmExpenses         PmExpense[]
  ownerMonthPayouts  OwnerMonthPayout[]

  @@index([code])
  @@index([status])
  @@map("properties")
}

model Tenant {
  id         String    @id @default(cuid())
  code       String    @unique
  name       String
  email      String?
  phone      String?
  unit       String?
  propertyId String?
  property   Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  moveIn     DateTime?
  leaseTo    DateTime?
  rent       Decimal   @default(0) @db.Decimal(10, 2)
  deposit    Decimal   @default(0) @db.Decimal(10, 2)
  tenantType String?
  status     String    @default("active")
  ssn        String?
  itin       String?
  tags       String[]
  notes      String?   @db.Text
  metadata   Json?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  createdBy  String?

  @@index([code])
  @@index([propertyId])
  @@index([status])
  @@map("tenants")
}

enum PmPackage {
  PACOTE_1
  PACOTE_2
  PACOTE_3
  PACOTE_4
}

enum PmExpenseStatus {
  SCHEDULED
  PAID
  PENDING
  CANCELLED
}

/// Fornecedores internos (markup / Owner Payment)
model PmVendor {
  id             String    @id @default(cuid())
  companyName    String
  contactName    String?
  email          String
  phone          String
  addressStreet  String
  addressCity    String?
  addressState   String?
  addressZip     String?
  trade          String?
  /// Tipo de serviço (texto livre)
  serviceType    String?
  defaultPackage PmPackage @default(PACOTE_1)
  bankName       String?
  routingNumber  String?
  accountNumber  String?
  accountType    String?
  paymentType    String?
  commissionMp   Boolean   @default(false)
  send1099       Boolean   @default(true)
  status         String    @default("Active")
  notes          String?   @db.Text
  metadata       Json?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  expenses       PmExpense[]

  @@index([companyName])
  @@map("pm_vendors")
}

model PmExpense {
  id              String          @id @default(cuid())
  propertyId      String
  property        Property        @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  vendorId        String?
  vendor          PmVendor?       @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  serviceType     String?
  packageApplied  PmPackage
  vendorCost      Decimal         @db.Decimal(12, 2)
  ownerCharged    Decimal         @db.Decimal(12, 2)
  serviceDate     DateTime?
  monthRef        String
  status          PmExpenseStatus @default(PENDING)
  description     String?         @db.Text
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([propertyId, monthRef])
  @@index([monthRef])
  @@index([vendorId])
  @@map("pm_expenses")
}

model OwnerMonthPayout {
  id         String    @id @default(cuid())
  propertyId String
  property   Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  yearMonth  String
  paidAt     DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([propertyId, yearMonth])
  @@index([yearMonth])
  @@map("owner_month_payouts")
}
