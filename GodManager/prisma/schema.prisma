// Prisma schema - GodManager
// Replica lib/types.ts: User + Client + AuditEntry
// Multi-tenant: User.clientId opcional (null = system admin)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  super_admin
  admin
  manager
  accountant
  leasing
  maintenance
  viewer
  owner
}

enum UserStatus {
  active
  suspended
  pending
}

enum ClientPlan {
  starter
  professional
  enterprise
}

// === STRIPE BILLING — Trial + Subscription ===

enum BusinessSegment {
  LONG_TERM
  SHORT_TERM
  HOSPITALITY
  REALTOR
  INSURANCE
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELLED
  EXPIRED
  GRANDFATHERED
}

enum BillingInterval {
  MONTHLY
  ANNUAL
}

model Client {
  id          String     @id @default(cuid())
  companyName String
  contactName String
  email       String     @unique
  phone       String?
  address     String?
  plan        ClientPlan @default(starter)
  accessLevel UserRole   @default(manager)
  active      Boolean    @default(true)
  logoUrl     String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  users       User[]

  // Multi-tenant back-relations
  owners                Owner[]                  @relation("Owner_clientId")
  properties            Property[]               @relation("Property_clientId")
  tenantsScope          Tenant[]                 @relation("Tenant_clientId")
  ownerPayouts          OwnerMonthPayout[]       @relation("OwnerMonthPayout_clientId")
  expenses              PmExpense[]              @relation("PmExpense_clientId")
  vendors               PmVendor[]               @relation("PmVendor_clientId")
  vendorPayments        VendorPayment[]          @relation("VendorPayment_clientId")
  maintenanceCalls      MaintenanceCall[]        @relation("MaintenanceCall_clientId")
  jobActions            JobAction[]              @relation("JobAction_clientId")
  propertyStatusHistory PropertyStatusHistory[]  @relation("PropertyStatusHistory_clientId")
  auditEntries          AuditEntry[]             @relation("AuditEntry_clientId")
  subscriptions         Subscription[]           @relation("Subscription_clientId")
  statementLineItems    StatementLineItem[]      @relation("StatementLineItem_clientId")
  userPermissions       UserPermission[]         @relation("UserPermission_clientId")

  @@map("clients")
}

model User {
  id           String       @id @default(cuid())
  firstName    String
  lastName     String
  email        String       @unique
  phone        String?
  role         UserRole     @default(viewer)
  status       UserStatus   @default(pending)
  permissions  String[]     @default([])
  passwordHash String
  createdAt    DateTime     @default(now())
  lastActive   DateTime     @default(now())
  clientId     String?
  ownerId      String?
  client       Client?      @relation(fields: [clientId], references: [id], onDelete: SetNull)
  owner        Owner?       @relation("User_ownerId", fields: [ownerId], references: [id], onDelete: SetNull)
  auditEntries AuditEntry[] @relation("ActorAudit")
  targetAudits AuditEntry[] @relation("TargetAudit")
  subscription Subscription?
  userPermissions UserPermission[] @relation("User_permissions")

  @@index([clientId])
  @@index([ownerId])
  @@index([email])
  @@map("users")
}

model UserPermission {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation("User_permissions", fields: [userId], references: [id], onDelete: Cascade)
  clientId  String?
  client    Client?  @relation("UserPermission_clientId", fields: [clientId], references: [id], onDelete: Cascade)
  resource  String   @db.VarChar(50)
  action    String   @db.VarChar(20)
  grantedBy String?
  grantedAt DateTime @default(now())
  notes     String?  @db.VarChar(300)

  @@unique([userId, clientId, resource, action])
  @@index([userId])
  @@index([clientId])
  @@index([resource])
  @@map("user_permissions")
}

model AuditEntry {
  id           String   @id @default(cuid())
  actorId      String?
  actor        User?    @relation("ActorAudit", fields: [actorId], references: [id], onDelete: SetNull)
  actorEmail   String?
  action       String
  entity       String   @default("")
  entityId     String?
  targetUserId String?
  targetUser   User?    @relation("TargetAudit", fields: [targetUserId], references: [id], onDelete: SetNull)
  details      String   @default("")
  ip           String?
  userAgent    String?
  timestamp    DateTime @default(now())
  clientId     String?
  client       Client?  @relation("AuditEntry_clientId", fields: [clientId], references: [id], onDelete: SetNull)

  @@index([actorId])
  @@index([targetUserId])
  @@index([entity])
  @@index([action])
  @@index([timestamp])
  @@index([clientId])
  @@map("audit_entries")
}

model AppSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt
  updatedBy String?

  @@index([key])
  @@map("app_settings")
}

model DemoLead {
  id          String      @id @default(cuid())
  nome        String
  empresa     String
  email       String
  telefone    String
  redeSocial  String?
  siteEmpresa String?
  ip          String?
  userAgent   String?
  createdAt   DateTime    @default(now())
  tokens      DemoToken[]

  @@index([email])
  @@index([createdAt])
  @@map("demo_leads")
}

model DemoToken {
  id        String    @id @default(cuid())
  token     String    @unique
  leadId    String
  lead      DemoLead  @relation(fields: [leadId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([token])
  @@index([expiresAt])
  @@map("demo_tokens")
}

model ContactLead {
  id           String   @id @default(cuid())
  nome         String
  email        String
  telefone     String
  empresa      String?
  tipoContacto String
  /// Texto do formulario; opcional
  mensagem     String?  @db.Text
  ip           String?
  userAgent    String?
  createdAt    DateTime @default(now())

  @@index([email])
  @@index([createdAt])
  @@map("contact_leads")
}

model Owner {
  id         String     @id @default(cuid())
  clientId   String
  client     Client     @relation("Owner_clientId", fields: [clientId], references: [id], onDelete: Cascade)
  name       String
  email      String?
  phone      String?
  notes      String?    @db.Text
  active     Boolean    @default(true)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  properties Property[] @relation("Property_ownerId")
  users      User[]     @relation("User_ownerId")

  @@unique([clientId, email])
  @@index([clientId])
  @@index([email])
  @@map("owners")
}

model Property {
  id                String                  @id @default(cuid())
  code              String                  @unique
  address           String
  city              String?
  state             String?
  zip               String?
  unitType          String?
  bedrooms          Int?
  bathrooms         Float?
  rent              Decimal                 @default(0) @db.Decimal(10, 2)
  deposit           Decimal                 @default(0) @db.Decimal(10, 2)
  guaranteeLimit    Decimal?                @db.Decimal(10, 2)
  moveInDate        DateTime?
  ownerName         String?
  ownerEmail        String?
  ownerPhone        String?
  ownerId           String?
  owner             Owner?                  @relation("Property_ownerId", fields: [ownerId], references: [id], onDelete: SetNull)
  mgmtFeePct        Decimal                 @default(0) @db.Decimal(5, 2)
  status            String                  @default("active")
  notes             String?                 @db.Text
  metadata          Json?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  createdBy         String?
  clientId          String?
  client            Client?                 @relation("Property_clientId", fields: [clientId], references: [id], onDelete: SetNull)
  tenants           Tenant[]
  pmExpenses        PmExpense[]
  ownerMonthPayouts OwnerMonthPayout[]
  maintenanceCalls  MaintenanceCall[]
  statusHistory     PropertyStatusHistory[]

  @@index([code])
  @@index([status])
  @@index([clientId])
  @@index([ownerId])
  @@map("properties")
}

model Tenant {
  id               String            @id @default(cuid())
  code             String            @unique
  name             String
  email            String?
  phone            String?
  unit             String?
  propertyId       String?
  property         Property?         @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  moveIn           DateTime?
  leaseTo          DateTime?
  rent             Decimal           @default(0) @db.Decimal(10, 2)
  deposit          Decimal           @default(0) @db.Decimal(10, 2)
  tenantType       String?
  status           String            @default("active")
  ssn              String?
  itin             String?
  tags             String[]
  notes            String?           @db.Text
  metadata         Json?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  createdBy        String?
  clientId         String?
  client           Client?           @relation("Tenant_clientId", fields: [clientId], references: [id], onDelete: SetNull)
  maintenanceCalls MaintenanceCall[]

  @@index([code])
  @@index([propertyId])
  @@index([status])
  @@index([clientId])
  @@map("tenants")
}

model MaintenanceCall {
  id         String    @id @default(cuid())
  tenantId   String?
  tenant     Tenant?   @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  propertyId String?
  property   Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  tipo       String
  descricao  String    @db.Text
  fotoUrl    String?   @db.Text
  status     String    @default("aberto")
  isAlert    Boolean   @default(true)
  createdBy  String?
  resolvedAt DateTime?
  resolvedBy String?
  notes      String?   @db.Text
  metadata   Json?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  clientId   String?
  client     Client?   @relation("MaintenanceCall_clientId", fields: [clientId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([propertyId])
  @@index([status])
  @@index([createdAt])
  @@index([clientId])
  @@map("maintenance_calls")
}

model JobAction {
  id         String   @id @default(cuid())
  jobId      String
  jobType    String   @default("expense")
  action     String
  reason     String?  @db.Text
  actorId    String?
  actorEmail String?
  metadata   Json?
  createdAt  DateTime @default(now())
  clientId   String?
  client     Client?  @relation("JobAction_clientId", fields: [clientId], references: [id], onDelete: SetNull)

  @@index([jobId])
  @@index([action])
  @@index([createdAt])
  @@index([clientId])
  @@map("job_actions")
}

model PropertyStatusHistory {
  id             String   @id @default(cuid())
  propertyId     String
  property       Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  fromStatus     String?
  toStatus       String
  changedBy      String?
  changedByEmail String?
  reason         String?
  metadata       Json?
  createdAt      DateTime @default(now())
  clientId       String?
  client         Client?  @relation("PropertyStatusHistory_clientId", fields: [clientId], references: [id], onDelete: SetNull)

  @@index([propertyId])
  @@index([createdAt])
  @@index([clientId])
  @@map("property_status_history")
}

enum PmPackage {
  PACOTE_1
  PACOTE_2
  PACOTE_3
  PACOTE_4
}

enum PmExpenseStatus {
  SCHEDULED
  PAID
  PENDING
  CANCELLED
  FINALIZED
}

/// Fornecedores internos (markup / Owner Payment)
model PmVendor {
  id             String          @id @default(cuid())
  companyName    String
  contactName    String?
  email          String
  phone          String
  addressStreet  String
  addressCity    String?
  addressState   String?
  addressZip     String?
  trade          String?
  /// Tipo de serviço (texto livre)
  serviceType    String?
  defaultPackage PmPackage       @default(PACOTE_1)
  bankName       String?
  routingNumber  String?
  accountNumber  String?
  accountType    String?
  paymentType    String?
  commissionMp   Boolean         @default(false)
  send1099       Boolean         @default(true)
  status         String          @default("Active")
  notes          String?         @db.Text
  source         String?
  reviewedAt     DateTime?
  metadata       Json?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  expenses       PmExpense[]
  payments       VendorPayment[]
  clientId       String?
  client         Client?         @relation("PmVendor_clientId", fields: [clientId], references: [id], onDelete: SetNull)

  @@index([companyName])
  @@index([clientId])
  @@map("pm_vendors")
}

model VendorPayment {
  id       String   @id @default(cuid())
  vendorId String
  vendor   PmVendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  amount   Decimal  @db.Decimal(10, 2)
  count    Int      @default(0)
  paidAt   DateTime @default(now())
  paidBy   String?
  metadata Json?
  clientId String?
  client   Client?  @relation("VendorPayment_clientId", fields: [clientId], references: [id], onDelete: SetNull)

  @@index([vendorId])
  @@index([paidAt])
  @@index([clientId])
  @@map("vendor_payments")
}

model PmExpense {
  id             String          @id @default(cuid())
  propertyId     String
  property       Property        @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  vendorId       String?
  vendor         PmVendor?       @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  serviceType    String?
  packageApplied PmPackage
  vendorCost     Decimal         @db.Decimal(12, 2)
  ownerCharged   Decimal         @db.Decimal(12, 2)
  serviceDate    DateTime?
  monthRef       String
  status         PmExpenseStatus @default(PENDING)
  description    String?         @db.Text
  finalizedAt    DateTime?
  finalizedBy    String?
  finalizedNote  String?         @db.Text
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  clientId       String?
  client         Client?         @relation("PmExpense_clientId", fields: [clientId], references: [id], onDelete: SetNull)

  @@index([propertyId, monthRef])
  @@index([monthRef])
  @@index([vendorId])
  @@index([clientId])
  @@map("pm_expenses")
}

model OwnerMonthPayout {
  id           String    @id @default(cuid())
  propertyId   String
  property     Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  yearMonth    String
  paidAt       DateTime?
  paidAmount   Decimal?  @db.Decimal(12, 2)
  method       String?   @db.VarChar(40)
  reference    String?   @db.VarChar(120)
  notes        String?   @db.Text
  paidById     String?
  paidByEmail  String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  clientId     String?
  client       Client?   @relation("OwnerMonthPayout_clientId", fields: [clientId], references: [id], onDelete: SetNull)

  totalIncome        Decimal?            @db.Decimal(12, 2)
  totalExpenses      Decimal?            @db.Decimal(12, 2)
  netPayout          Decimal?            @db.Decimal(12, 2)
  previousBalance    Decimal?            @default(0) @db.Decimal(12, 2)
  statementLineItems StatementLineItem[]

  @@unique([propertyId, yearMonth])
  @@index([yearMonth])
  @@index([clientId])
  @@map("owner_month_payouts")
}

model StatementLineItem {
  id                 String           @id @default(cuid())
  ownerMonthPayoutId String
  ownerMonthPayout   OwnerMonthPayout @relation(fields: [ownerMonthPayoutId], references: [id], onDelete: Cascade)
  lineType           String           @db.VarChar(20)
  description        String           @db.VarChar(300)
  amount             Decimal          @db.Decimal(12, 2)
  sortOrder          Int              @default(0)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  clientId           String?
  client             Client?          @relation("StatementLineItem_clientId", fields: [clientId], references: [id], onDelete: SetNull)

  @@index([ownerMonthPayoutId])
  @@index([clientId])
  @@map("statement_line_items")
}

model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique
  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  stripeCustomerId     String?            @unique
  stripeSubscriptionId String?            @unique
  stripePriceId        String?

  trialStartsAt        DateTime?          @default(now())
  trialEndsAt          DateTime?

  status               SubscriptionStatus @default(TRIAL)
  segment              BusinessSegment?
  packageTier          Int?
  interval             BillingInterval?   @default(MONTHLY)

  avgRent              Decimal?           @db.Decimal(12, 2)
  avgVgv               Decimal?           @db.Decimal(14, 2)
  unitCount            Int?
  pricePerUnit         Decimal?           @db.Decimal(10, 2)
  totalMonthly         Decimal?           @db.Decimal(12, 2)

  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)

  isGrandfathered      Boolean            @default(false)
  grandfatheredNote    String?            @db.Text

  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  clientId             String?
  client               Client?            @relation("Subscription_clientId", fields: [clientId], references: [id], onDelete: SetNull)

  events               BillingEvent[]

  @@index([status])
  @@index([trialEndsAt])
  @@index([clientId])
  @@map("subscriptions")
}

model BillingEvent {
  id             String       @id @default(cuid())
  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  eventType       String
  stripeEventId   String?      @unique
  stripeEventType String?
  amount         Decimal?     @db.Decimal(12, 2)
  metadata       Json?
  createdAt      DateTime     @default(now())

  @@index([subscriptionId])
  @@index([createdAt])
  @@map("billing_events")
}

model PricingLead {
  id                        String           @id @default(cuid())
  email                     String
  businessType              String // wizard key: realtor | longterm | pm | insurance | maintenance | other | ...
  segment                   BusinessSegment?
  packageTier               Int?
  avgRent                   Decimal?         @db.Decimal(12, 2)
  avgVgv                    Decimal?         @db.Decimal(14, 2)
  unitCount                 Int?
  properties                Int?
  systems                   String[]
  pricePerUnit              Decimal?         @db.Decimal(10, 4)
  monthlyTotal              Decimal?         @db.Decimal(12, 2)
  annualTotal               Decimal?         @db.Decimal(14, 2)
  source                    String           @default("savings_wizard")
  ipAddress                 String?
  userAgent                 String?
  convertedToSubscription   Boolean          @default(false)
  createdAt                 DateTime         @default(now())

  @@index([email])
  @@index([createdAt])
  @@map("pricing_leads")
}
