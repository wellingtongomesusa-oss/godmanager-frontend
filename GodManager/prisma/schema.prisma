  clientId      String
  filename      String
  contentHash   String    @unique
  rowCount      Int
  periodStart   DateTime?
  periodEnd     DateTime?
  uploadedById  String?
  uploadedBy    String?
  uploadedAt    DateTime  @default(now())

  client Client  @relation("LeaseImport_clientId", fields: [clientId], references: [id], onDelete: Restrict)
  leases Lease[]

  @@index([clientId])
  @@index([uploadedAt])
  @@map("lease_imports")
}

model Lease {
  id              String       @id @default(cuid())
  clientId        String
  leaseImportId   String

  propertyId String?
  tenantId   String?

  propertyAddress String
  unit            String?
  tenantName      String

  leaseStart      DateTime?
  leaseEnd        DateTime?
  monthlyRent     Decimal?     @db.Decimal(12, 2)
  securityDeposit Decimal?     @db.Decimal(12, 2)
  status          LeaseStatus  @default(UNKNOWN)
  notes           String?      @db.Text

  leaseHash String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client      Client       @relation("Lease_clientId", fields: [clientId], references: [id], onDelete: Restrict)
  leaseImport LeaseImport @relation(fields: [leaseImportId], references: [id], onDelete: Cascade)
  property    Property?    @relation("Lease_propertyId", fields: [propertyId], references: [id], onDelete: SetNull)
  tenant      Tenant?      @relation("Lease_tenantId", fields: [tenantId], references: [id], onDelete: SetNull)

  @@unique([clientId, leaseHash])
  @@index([clientId, status])
  @@index([clientId, leaseEnd])
  @@index([propertyId])
  @@index([tenantId])
  @@map("leases")
}

