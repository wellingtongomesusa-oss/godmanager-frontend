enum CommentEntityType {
  JOB
  EXPENSE
  PROPERTY
  TENANT
  VENDOR
}

model Comment {
  id         String            @id @default(cuid())
  clientId   String
  entityType CommentEntityType
  entityId   String
  authorId   String
  authorName String
  authorRole String
  content    String            @db.Text
  metadata   Json?
  isInternal Boolean           @default(false)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  deletedAt  DateTime?

  client Client @relation(fields: [clientId], references: [id], onDelete: Restrict)
  author User   @relation(fields: [authorId], references: [id], onDelete: Restrict)

  @@index([clientId, entityType, entityId])
  @@index([authorId])
  @@index([createdAt])
  @@map("comments")
}

enum GLEntryType {
  CHECK
  RECEIPT
  ECHECK
  ECHECK_RECEIPT
  PAYMENT
  JE
  CC_RECEIPT
  REVERSE_RECEIPT
  REVERSED_ECHECK_RECEIPT
  BANK_TRANSFER
  CHECK_SEND
  OTHER
}

enum GLEntryPaidStatus {
  UNPAID
  PAID
  VOID
  REVERSED
}

model GLImport {
  id           String    @id @default(cuid())
  clientId     String
  filename     String
  contentHash  String    @unique
  sourceFormat String    @default("appfolio_gl")
  rowCount     Int
  totalDebit   Decimal?  @db.Decimal(14, 2)
  totalCredit  Decimal?  @db.Decimal(14, 2)
  periodStart  DateTime?
  periodEnd    DateTime?
  uploadedById String?
  uploadedBy   String?
  r2Key        String?
  uploadedAt   DateTime  @default(now())

  client  Client    @relation("GLImport_clientId", fields: [clientId], references: [id])
  entries GLEntry[]

  @@index([clientId])
  @@index([uploadedAt])
  @@map("gl_imports")
}

model GLEntry {
  id              String              @id @default(cuid())
  clientId        String
  glImportId      String
  propertyId      String?
  propertyAddress String
  entryDate       DateTime
  payee           String?
  entryType       GLEntryType
  reference       String?
  debit           Decimal?            @db.Decimal(14, 2)
  credit          Decimal?            @db.Decimal(14, 2)
  balance         Decimal?            @db.Decimal(14, 2)
  description     String?             @db.Text
  account         String?
  accountCode     String?
  paidStatus      GLEntryPaidStatus   @default(UNPAID)
  paidAt          DateTime?
  paidById        String?
  paidByName      String?
  paidMethod      String?
  paidNotes       String?             @db.Text
  txnHash         String
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  client   Client    @relation("GLEntry_clientId", fields: [clientId], references: [id])
  glImport GLImport  @relation(fields: [glImportId], references: [id], onDelete: Cascade)
  property Property? @relation("GLEntry_propertyId", fields: [propertyId], references: [id], onDelete: SetNull)

  @@unique([clientId, txnHash])
  @@index([clientId, entryDate])
  @@index([clientId, payee])
  @@index([clientId, entryType])
  @@index([clientId, accountCode])
  @@index([clientId, paidStatus])
  @@index([propertyId])
  @@map("gl_entries")
}

model AnalyticsSnapshot {
