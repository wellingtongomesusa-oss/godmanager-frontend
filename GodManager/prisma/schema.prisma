// Prisma schema - GodManager
// Replica lib/types.ts: User + Client + AuditEntry
// Multi-tenant: User.clientId opcional (null = system admin)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  manager
  accountant
  leasing
  maintenance
  viewer
}

enum UserStatus {
  active
  suspended
  pending
}

enum ClientPlan {
  starter
  professional
  enterprise
}

model Client {
  id          String     @id @default(cuid())
  companyName String
  contactName String
  email       String     @unique
  phone       String?
  address     String?
  plan        ClientPlan @default(starter)
  accessLevel UserRole   @default(manager)
  active      Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  users       User[]

  @@map("clients")
}

model User {
  id           String       @id @default(cuid())
  firstName    String
  lastName     String
  email        String       @unique
  phone        String?
  role         UserRole     @default(viewer)
  status       UserStatus   @default(pending)
  permissions  String[]     @default([])
  passwordHash String
  createdAt    DateTime     @default(now())
  lastActive   DateTime     @default(now())
  clientId     String?
  client       Client?      @relation(fields: [clientId], references: [id], onDelete: SetNull)
  auditEntries AuditEntry[] @relation("ActorAudit")
  targetAudits AuditEntry[] @relation("TargetAudit")

  @@index([clientId])
  @@index([email])
  @@map("users")
}

model AuditEntry {
  id           String   @id @default(cuid())
  actorId      String?
  actor        User?    @relation("ActorAudit", fields: [actorId], references: [id], onDelete: SetNull)
  actorEmail   String?
  action       String
  entity       String   @default("")
  entityId     String?
  targetUserId String?
  targetUser   User?    @relation("TargetAudit", fields: [targetUserId], references: [id], onDelete: SetNull)
  details      String   @default("")
  ip           String?
  userAgent    String?
  timestamp    DateTime @default(now())

  @@index([actorId])
  @@index([targetUserId])
  @@index([entity])
  @@index([action])
  @@index([timestamp])
  @@map("audit_entries")
}

model AppSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt
  updatedBy String?

  @@index([key])
  @@map("app_settings")
}

model DemoLead {
  id          String      @id @default(cuid())
  nome        String
  empresa     String
  email       String
  telefone    String
  redeSocial  String?
  siteEmpresa String?
  ip          String?
  userAgent   String?
  createdAt   DateTime    @default(now())
  tokens      DemoToken[]

  @@index([email])
  @@index([createdAt])
  @@map("demo_leads")
}

model DemoToken {
  id        String    @id @default(cuid())
  token     String    @unique
  leadId    String
  lead      DemoLead  @relation(fields: [leadId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([token])
  @@index([expiresAt])
  @@map("demo_tokens")
}

model ContactLead {
  id           String   @id @default(cuid())
  nome         String
  email        String
  telefone     String
  empresa      String?
  tipoContacto String
  /// Texto do formulario; opcional
  mensagem     String?  @db.Text
  ip           String?
  userAgent    String?
  createdAt    DateTime @default(now())

  @@index([email])
  @@index([createdAt])
  @@map("contact_leads")
}

model Property {
  id                String                  @id @default(cuid())
  code              String                  @unique
  address           String
  city              String?
  state             String?
  zip               String?
  unitType          String?
  bedrooms          Int?
  bathrooms         Float?
  rent              Decimal                 @default(0) @db.Decimal(10, 2)
  deposit           Decimal                 @default(0) @db.Decimal(10, 2)
  guaranteeLimit    Decimal?                @db.Decimal(10, 2)
  moveInDate        DateTime?
  ownerName         String?
  ownerEmail        String?
  ownerPhone        String?
  mgmtFeePct        Decimal                 @default(0) @db.Decimal(5, 2)
  status            String                  @default("active")
  notes             String?                 @db.Text
  metadata          Json?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  createdBy         String?
  tenants           Tenant[]
  pmExpenses        PmExpense[]
  ownerMonthPayouts OwnerMonthPayout[]
  maintenanceCalls  MaintenanceCall[]
  statusHistory     PropertyStatusHistory[]

  @@index([code])
  @@index([status])
  @@map("properties")
}

model Tenant {
  id               String            @id @default(cuid())
  code             String            @unique
  name             String
  email            String?
  phone            String?
  unit             String?
  propertyId       String?
  property         Property?         @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  moveIn           DateTime?
  leaseTo          DateTime?
  rent             Decimal           @default(0) @db.Decimal(10, 2)
  deposit          Decimal           @default(0) @db.Decimal(10, 2)
  tenantType       String?
  status           String            @default("active")
  ssn              String?
  itin             String?
  tags             String[]
  notes            String?           @db.Text
  metadata         Json?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  createdBy        String?
  maintenanceCalls MaintenanceCall[]

  @@index([code])
  @@index([propertyId])
  @@index([status])
  @@map("tenants")
}

model MaintenanceCall {
  id         String    @id @default(cuid())
  tenantId   String?
  tenant     Tenant?   @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  propertyId String?
  property   Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  tipo       String
  descricao  String    @db.Text
  fotoUrl    String?   @db.Text
  status     String    @default("aberto")
  isAlert    Boolean   @default(true)
  createdBy  String?
  resolvedAt DateTime?
  resolvedBy String?
  notes      String?   @db.Text
  metadata   Json?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([tenantId])
  @@index([propertyId])
  @@index([status])
  @@index([createdAt])
  @@map("maintenance_calls")
}

model JobAction {
  id         String   @id @default(cuid())
  jobId      String
  jobType    String   @default("expense")
  action     String
  reason     String?  @db.Text
  actorId    String?
  actorEmail String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([jobId])
  @@index([action])
  @@index([createdAt])
  @@map("job_actions")
}

model PropertyStatusHistory {
  id             String   @id @default(cuid())
  propertyId     String
  property       Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  fromStatus     String?
  toStatus       String
  changedBy      String?
  changedByEmail String?
  reason         String?
  metadata       Json?
  createdAt      DateTime @default(now())

  @@index([propertyId])
  @@index([createdAt])
  @@map("property_status_history")
}

enum PmPackage {
  PACOTE_1
  PACOTE_2
  PACOTE_3
  PACOTE_4
}

enum PmExpenseStatus {
  SCHEDULED
  PAID
  PENDING
  CANCELLED
}

/// Fornecedores internos (markup / Owner Payment)
model PmVendor {
  id             String          @id @default(cuid())
  companyName    String
  contactName    String?
  email          String
  phone          String
  addressStreet  String
  addressCity    String?
  addressState   String?
  addressZip     String?
  trade          String?
  /// Tipo de serviço (texto livre)
  serviceType    String?
  defaultPackage PmPackage       @default(PACOTE_1)
  bankName       String?
  routingNumber  String?
  accountNumber  String?
  accountType    String?
  paymentType    String?
  commissionMp   Boolean         @default(false)
  send1099       Boolean         @default(true)
  status         String          @default("Active")
  notes          String?         @db.Text
  source         String?
  reviewedAt     DateTime?
  metadata       Json?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  expenses       PmExpense[]
  payments       VendorPayment[]

  @@index([companyName])
  @@map("pm_vendors")
}

model VendorPayment {
  id       String   @id @default(cuid())
  vendorId String
  vendor   PmVendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  amount   Decimal  @db.Decimal(10, 2)
  count    Int      @default(0)
  paidAt   DateTime @default(now())
  paidBy   String?
  metadata Json?

  @@index([vendorId])
  @@index([paidAt])
  @@map("vendor_payments")
}

model PmExpense {
  id             String          @id @default(cuid())
  propertyId     String
  property       Property        @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  vendorId       String?
  vendor         PmVendor?       @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  serviceType    String?
  packageApplied PmPackage
  vendorCost     Decimal         @db.Decimal(12, 2)
  ownerCharged   Decimal         @db.Decimal(12, 2)
  serviceDate    DateTime?
  monthRef       String
  status         PmExpenseStatus @default(PENDING)
  description    String?         @db.Text
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([propertyId, monthRef])
  @@index([monthRef])
  @@index([vendorId])
  @@map("pm_expenses")
}

model OwnerMonthPayout {
  id         String    @id @default(cuid())
  propertyId String
  property   Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  yearMonth  String
  paidAt     DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([propertyId, yearMonth])
  @@index([yearMonth])
  @@map("owner_month_payouts")
}
