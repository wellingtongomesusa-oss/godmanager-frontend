// Prisma schema - GodManager
// Replica lib/types.ts: User + Client + AuditEntry
// Multi-tenant: User.clientId opcional (null = system admin)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  manager
  accountant
  leasing
  maintenance
  viewer
}

enum UserStatus {
  active
  suspended
  pending
}

enum ClientPlan {
  starter
  professional
  enterprise
}

model Client {
  id          String     @id @default(cuid())
  companyName String
  contactName String
  email       String     @unique
  phone       String?
  address     String?
  plan        ClientPlan @default(starter)
  accessLevel UserRole   @default(manager)
  active      Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  users       User[]

  @@map("clients")
}

model User {
  id           String       @id @default(cuid())
  firstName    String
  lastName     String
  email        String       @unique
  phone        String?
  role         UserRole     @default(viewer)
  status       UserStatus   @default(pending)
  permissions  String[]     @default([])
  passwordHash String
  createdAt    DateTime     @default(now())
  lastActive   DateTime     @default(now())
  clientId     String?
  client       Client?      @relation(fields: [clientId], references: [id], onDelete: SetNull)
  auditEntries AuditEntry[] @relation("ActorAudit")
  targetAudits AuditEntry[] @relation("TargetAudit")

  @@index([clientId])
  @@index([email])
  @@map("users")
}

model AuditEntry {
  id           String   @id @default(cuid())
  actorId      String
  actor        User     @relation("ActorAudit", fields: [actorId], references: [id], onDelete: Cascade)
  action       String
  targetUserId String?
  targetUser   User?    @relation("TargetAudit", fields: [targetUserId], references: [id], onDelete: SetNull)
  details      String
  ip           String?
  timestamp    DateTime @default(now())

  @@index([actorId])
  @@index([targetUserId])
  @@index([timestamp])
  @@map("audit_entries")
}

model Property {
  id         String   @id @default(cuid())
  code       String   @unique
  address    String
  city       String?
  state      String?
  zip        String?
  unitType   String?
  bedrooms   Int?
  bathrooms  Float?
  rent       Decimal  @default(0) @db.Decimal(10, 2)
  deposit    Decimal  @default(0) @db.Decimal(10, 2)
  ownerName  String?
  ownerEmail String?
  ownerPhone String?
  mgmtFeePct Decimal  @default(0) @db.Decimal(5, 2)
  status     String   @default("active")
  notes      String?  @db.Text
  metadata   Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  createdBy  String?

  @@index([code])
  @@index([status])
  @@map("properties")
}
