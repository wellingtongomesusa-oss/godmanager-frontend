# Copie para `.env` na raiz do GodManager e preencha.
# QuickBooks (Intuit Developer) — OAuth2
QB_CLIENT_ID=
QB_CLIENT_SECRET=
QB_REDIRECT_URI=http://localhost:3101/crm/integrations/quickbooks/callback
QB_ENVIRONMENT=sandbox
QB_BASE_URL=https://sandbox-quickbooks.api.intuit.com

# ─── Cloudflare R2 (Photo Storage) ──────────────────────
# Get these values from Cloudflare R2 dashboard:
# https://dash.cloudflare.com → R2 Object Storage
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=godmanager-properties
R2_ENDPOINT=
R2_PUBLIC_URL=
