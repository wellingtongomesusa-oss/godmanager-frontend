# Copie para `.env` ou `.env.local` na raiz do GodManager e preencha.

# Postgres (obrigatório para login e API). Em dev, DATABASE_URL deve apontar para a BD
# onde corres `next dev`; use DATABASE_URL_LOCAL + scripts npm (db:local:* / dev:local)
# para nunca aplicar migrações acidentalmente na produção.
# Com docker compose na raiz:
# DATABASE_URL="postgresql://godmanager:godmanager@127.0.0.1:5433/godmanager?schema=public"
DATABASE_URL=

# Local Postgres (docker-compose up -d postgres; porta 5433 no host)
DATABASE_URL_LOCAL=postgresql://godmanager:godmanager@127.0.0.1:5433/godmanager?schema=public

# QuickBooks (Intuit Developer) — OAuth2
QB_CLIENT_ID=
QB_CLIENT_SECRET=
QB_REDIRECT_URI=http://localhost:3101/crm/integrations/quickbooks/callback
QB_ENVIRONMENT=sandbox
QB_BASE_URL=https://sandbox-quickbooks.api.intuit.com

# ─── Cloudflare R2 (Photo Storage) ──────────────────────
# Get these values from Cloudflare R2 dashboard:
# https://dash.cloudflare.com → R2 Object Storage
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=godmanager-properties
R2_ENDPOINT=
R2_PUBLIC_URL=

# Cron secret for GET /api/analytics/snapshot?secret=
CRON_SECRET=
# Fallback alert recipient if no active super_admin (optional)
ANALYTICS_ALERT_EMAIL=
