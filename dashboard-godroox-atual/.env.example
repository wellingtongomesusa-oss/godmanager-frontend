# Acesso exclusivo ao dashboard – usuário e senha master
MASTER_USER=master
MASTER_PASSWORD=SenhaMaster123!

# Opcional: se não definir MASTER_PASSWORD, o login master não funciona
# (use senha forte em produção)

# URL do frontend Godroox (onde os cadastros são feitos)
# O dashboard consome os dados do frontend por esta URL
NEXT_PUBLIC_GODROOX_API_URL=http://localhost:3000

# GodCRM (dashboard-novo, porta 3000) – link "Ver GodCRM" no menu
NEXT_PUBLIC_GODCRM_DASHBOARD_URL=http://localhost:3000

# Chave que o dashboard envia ao frontend para acessar a API de cadastros.
# Deve ser igual a DASHBOARD_API_SECRET (ou MASTER_PASSWORD) no .env do frontend.
DASHBOARD_API_SECRET=SenhaMaster123!

# xAI (Grok) API – Assistente de IA
# Obtenha sua chave em https://console.x.ai
XAI_API_KEY=xai-sua-chave-aqui
